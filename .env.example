# Copy to .env (gitignored -- this holds machine-local settings). Loaded
# automatically by agent/config.py via python-dotenv, so it applies to
# `make run`/`make chat`/`make eval`/`make compose-eval` and direct
# `uv run python -m agent` alike.

# agent.toml [models] key used when --model isn't passed explicitly --
# overrides agent.toml's default_model via pydantic-settings' AGENT_ env
# prefix (see agent/config.py). For a local model, also add a matching entry
# to local_models.toml (see local_models.toml.example) so its llama-server
# auto-starts/stops.
AGENT_DEFAULT_MODEL=replay

# API keys for cloud-hosted models (only needed for models you use; each
# agent.toml [models.<key>] entry names its env var via api_key_env).
# ANTHROPIC_API_KEY=sk-ant-...

# Container compose command, read by the Makefile (not by the agent). Set
# this if you use podman instead of docker, e.g.:
# COMPOSE=podman compose
